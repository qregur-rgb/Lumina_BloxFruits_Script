-- Загрузка UI библиотеки
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Создание окна
local Window = Rayfield:CreateWindow({
    Name = "Lumina Workshop | Blox Fruits",
    LoadingTitle = "Lumina ESP System",
    LoadingSubtitle = "by Lumina",
    ConfigurationSaving = { Enabled = true, FolderName = "LuminaConfigs" }
})

-- Функция для ESP
local function ToggleESP(name, state)
    -- Функция для удаления старых подссветок
    local function clearHighlights(parent)
        for _, obj in pairs(parent:GetDescendants()) do
            if obj.Name == "LuminaHighlight" then obj:Destroy() end
        end
    end

    if name == "Player ESP" then
        for _, player in pairs(game.Players:GetPlayers()) do
            if player.Character then
                if state then
                    local highlight = Instance.new("Highlight", player.Character)
                    highlight.Name = "LuminaHighlight"
                    highlight.FillColor = Color3.fromRGB(255, 0, 0)
                else
                    clearHighlights(player.Character)
                end
            end
        end
    elseif name == "Fruit ESP" then
        for _, item in pairs(workspace:GetDescendants()) do
            if item.Name:find("Fruit") and item:IsA("Model") then
                if state then
                     local highlight = Instance.new("Highlight", item)
                     highlight.Name = "LuminaHighlight"
                     highlight.FillColor = Color3.fromRGB(255, 255, 0)
                else
                     clearHighlights(item)
                end
            end
        end
    elseif name == "Chest ESP" then
        for _, item in pairs(workspace:GetDescendants()) do
            if item.Name:find("Chest") and item:IsA("Model") then
                if state then
                     local highlight = Instance.new("Highlight", item)
                     highlight.Name = "LuminaHighlight"
                     highlight.FillColor = Color3.fromRGB(0, 0, 255)
                else
                     clearHighlights(item)
                end
            end
        end
    end
end

-- Создание вкладок и кнопок
local Tab = Window:CreateTab("ESP", nil)

Tab:CreateToggle({
    Name = "Player ESP",
    CurrentValue = false,
    Callback = function(Value) ToggleESP("Player ESP", Value) end
})

Tab:CreateToggle({
    Name = "Fruit ESP",
    CurrentValue = false,
    Callback = function(Value) ToggleESP("Fruit ESP", Value) end
})

Tab:CreateToggle({
    Name = "Chest ESP",
    CurrentValue = false,
    Callback = function(Value) ToggleESP("Chest ESP", Value) end
})

Rayfield:Notify({
    Title = "Lumina Workshop",
    Content = "ESP System Loaded Successfully!",
    Duration = 5
})
