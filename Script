-- Загрузка UI библиотеки Rayfield
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Создание главного окна Lumina Workshop
local Window = Rayfield:CreateWindow({
    Name = "Lumina Workshop | Blox Fruits v1.0",
    LoadingTitle = "Lumina ESP System",
    LoadingSubtitle = "by Lumina",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "LuminaConfigs",
    }
})

-- Создание вкладки для ESP
local ESPTab = Window:CreateTab("ESP Visuals", nil) -- 'nil' значит иконки нет
local Section = ESPTab:CreateSection("ESP Features")

-- Функция для ESP (сюда ты будешь вставлять логику рисования)
local function ToggleESP(name, state)
    -- Player ESP
    if name == "Player ESP" then
        for _, player in pairs(game.Players:GetPlayers()) do
            if player.Character then
                if state then
                    local highlight = Instance.new("Highlight", player.Character)
                    highlight.Name = "LuminaHighlight"
                    highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Красный
                else
                    if player.Character:FindFirstChild("LuminaHighlight") then
                        player.Character.LuminaHighlight:Destroy()
                    end
                end
            end
        end
    -- Fruit ESP
    elseif name == "Fruit ESP" then
        for _, item in pairs(workspace:GetDescendants()) do
            if item.Name:find("Fruit") and item:IsA("Model") then
                if state then
                     local highlight = Instance.new("Highlight", item)
                     highlight.Name = "LuminaHighlight"
                     highlight.FillColor = Color3.fromRGB(255, 255, 0) -- Желтый
                else
                     for _, h in pairs(item:GetChildren()) do 
                         if h.Name == "LuminaHighlight" then h:Destroy() end 
                     end
                end
            end
        end
    -- Chest ESP
    elseif name == "Chest ESP" then
        for _, item in pairs(workspace:GetDescendants()) do
            if item.Name:find("Chest") and item:IsA("Model") then
                if state then
                     local highlight = Instance.new("Highlight", item)
                     highlight.Name = "LuminaHighlight"
                     highlight.FillColor = Color3.fromRGB(0, 0, 255) -- Синий
                else
                     for _, h in pairs(item:GetChildren()) do 
                         if h.Name == "LuminaHighlight" then h:Destroy() end 
                     end
                end
            end
        end
    end
end


-- Уведомление при запуске
Rayfield:Notify({
    Title = "Lumina Workshop",
    Content = "ESP System Loaded Successfully!",
    Duration = 5,
    Image = nil,
})
